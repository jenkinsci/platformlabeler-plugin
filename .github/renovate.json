{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>jenkinsci/renovate-config"
  ],
  "separateMinorPatch": true,
  "packageRules": [
    {
      "description": "Allow very large updates of plugin BOM",
      "matchPackageNames": ["io.jenkins.tools.bom:bom-*"],
      "maxMajorIncrement": 30000
    },
    {
      "description": "Disallow Debian major version upgrades",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["debian"],
      "matchFileNames": ["**/debian/1*/Dockerfile"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Only allow patch version updates to Alpine and Rocky Dockerfiles",
      "matchDatasources": ["docker"],
      "matchFileNames": ["**/alpine/*/Dockerfile", "**/rocky/*/Dockerfile"],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    },
    {
      "description": "Disallow AlmaLinux major version upgrades",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["almalinux"],
      "matchFileNames": ["**/almalinux/*/Dockerfile"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Limit Azure Linux 3.0 version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["azurelinux"],
      "matchFileNames": ["**/azurelinux/3.0/Dockerfile"],
      "allowedVersions": "<4"
    },
    {
      "description": "Limit Oracle Linux 8 Dockerfile version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["container-registry.oracle.com/os/oraclelinux"],
      "matchFileNames": ["**/oraclelinux/8.*/Dockerfile"],
      "allowedVersions": "<9"
    },
    {
      "description": "Limit Oracle Linux 9 Dockerfile version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["container-registry.oracle.com/os/oraclelinux"],
      "matchFileNames": ["**/oraclelinux/9.*/Dockerfile"],
      "allowedVersions": "<10"
    },
    {
      "description": "Limit Oracle Linux 10 Dockerfile version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["container-registry.oracle.com/os/oraclelinux"],
      "matchFileNames": ["**/oraclelinux/10.*/Dockerfile"],
      "allowedVersions": "<11"
    },
    {
      "description": "Limit openSUSE 16 Dockerfile version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["opensuse/leap"],
      "matchFileNames": ["**/opensuse-leap/16.*/Dockerfile"],
      "allowedVersions": "<17"
    },
    {
      "description": "Limit Fedora 43 Dockerfile version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["fedora"],
      "matchFileNames": ["**/fedora/43/Dockerfile"],
      "allowedVersions": "<44"
    },
    {
      "description": "Limit Fedora 44 Dockerfile version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["fedora"],
      "matchFileNames": ["**/fedora/44/Dockerfile"],
      "allowedVersions": "<45"
    },
    {
      "description": "Limit Ubuntu 22 Dockerfile version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ubuntu"],
      "matchFileNames": ["**/ubuntu/22.*/Dockerfile"],
      "allowedVersions": "<23"
    },
    {
      "description": "Limit Ubuntu 24 Dockerfile version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ubuntu"],
      "matchFileNames": ["**/ubuntu/24.*/Dockerfile"],
      "allowedVersions": "<25"
    },
    {
      "description": "Limit Ubuntu 26 Dockerfile version updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ubuntu"],
      "matchFileNames": ["**/ubuntu/26.*/Dockerfile"],
      "allowedVersions": "<27"
    }
  ]
}
